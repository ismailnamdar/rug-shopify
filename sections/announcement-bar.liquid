{%- liquid
  assign show_section = true
  if section.settings.hide_homepage and request.page_type == 'index'
    assign show_section = false
  endif

  assign section_rendering_api = false
  if section.index == nil
    assign section_rendering_api = true
  endif
-%}

{%- if show_section -%}
  <style>
    :root {
      --topbar-height: var(--sp-12);
    }
    
    @media screen and (min-width: 1536px) {
      :root {
        --topbar-height: var(--sp-14);
      }
    }

    #shopify-section-{{ section.id }} {
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.color_background }}{% endif %};
      --color-background: {{ section.settings.color_background.rgb }};
      --color-foreground: {{ section.settings.color_text.rgb }};
      --color-highlight: {{ section.settings.color_highlight.rgb }};
      --animation-smooth: 0.7s cubic-bezier(0.7, 0, 0.3, 1);
    }
  </style>

  {%- liquid
    assign announcements_count = section.blocks.size
    if section.settings.enable_language_selector and localization.available_languages.size > 1
      assign enable_language_selector = true
    endif
    if section.settings.enable_country_selector and localization.available_countries.size > 1
      assign enable_country_selector = true
    endif
  -%}

  <nav class="topbar topbar--{{ section.settings.announcement_position }}{% if section.settings.invert_icons_selectors %} topbar--inverted{% endif %}{% unless section.settings.show_social or enable_language_selector or enable_country_selector %} topbar--only{% endunless %} page-width{% if section.settings.full_width %} page-width--full{% endif %} section{% if section.settings.rounded %} section--rounded{% endif %} relative grid py-0 h-full w-full items-center" aria-label="{{ 'sections.announcements.announcement_bar' | t | escape }}">
    {%- if section.settings.show_social -%}
      <div class="social-icons hidden lg:flex items-center">
        {%- render 'social-icons-v2', size: 'sm', gap: '6' -%}
      </div>
    {%- endif -%}

    {%- liquid
      if announcements_count > 0
        if section.settings.announcement_layout == 'carousel'
          render 'announcements-carousel', section: section, announcements_count: announcements_count
        else
          render 'announcements-marquee', section: section, announcements_count: announcements_count
        endif
      endif
    -%}

    {%- if enable_language_selector or enable_country_selector -%}
      <div class="localization hidden lg:flex items-center h-full">
        {%- if enable_language_selector -%}
          <div class="localization__item h-full relative" role="combobox" aria-controls="LanguageLocalization-{{ section.id }}" aria-expanded="false" aria-label="{{ 'localization.language_label' | t | escape }}">
            <button type="button" class="flex items-center gap-3 h-full z-2 relative">
              {%- unless section_rendering_api -%}
                <api-button class="api-only" data-id="announcement_localization_language_form" data-section-id="{{ section.id }}"></api-button>
              {%- endunless -%}
              {%- render 'icon', icon: 'language', size: 'xs', class: 'stroke-1 hidden xl:block' -%}
              <span class="leading-tight">{{ localization.language.endonym_name | capitalize }}</span>
              {%- render 'icon', icon: 'chevron-down', size: 'xs' -%}
            </button>
            <dropdown-localization class="dropdown opacity-0 invisible z-30 absolute top-100{% if enable_country_selector %} left-0{% else %} right-0{% endif %} pointer-events-none" id="LanguageLocalization-{{ section.id }}">
              {%- unless section_rendering_api -%}
                <div class="dropdown__container" id="announcement_localization_language_form"></div>
              {%- else -%}
                {%- form 'localization', id: 'announcement_localization_language_form', class: 'dropdown__container', is: 'localization-listbox' -%}
                  {%- render 'corner', dir: 'top', prefix: 'dropdown' -%}
                  <ul class="dropdown__nav flex flex-col gap-1d5 xl:gap-2" role="list">
                    {%- for language in localization.available_languages -%}
                      <li class="opacity-0">
                        <p>
                          <a class="reversed-link{% if language.iso_code == localization.language.iso_code %} active pointer-events-none{% endif %}"
                            href="#"
                            hreflang="{{ language.iso_code }}"
                            lang="{{ language.iso_code }}"
                            {% if language.iso_code == localization.language.iso_code %}
                              aria-current="true"
                            {% endif %}
                            data-value="{{ language.iso_code }}"
                            title="{{ language.endonym_name | capitalize | escape }}"
                            data-no-instant
                          >
                            {{- language.endonym_name | capitalize -}}
                          </a>
                        </p>
                      </li>
                    {%- endfor -%}
                  </ul>
                  <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}" />
                {%- endform -%}
              {%- endunless -%}
            </dropdown-localization>
          </div>
        {%- endif -%}
        {%- if enable_country_selector -%}
          <div class="localization__item h-full relative" role="combobox" aria-controls="CountryLocalization-{{ section.id }}" aria-expanded="false" aria-label="{{ 'localization.country_label' | t | escape }}">
            <button type="button" class="flex items-center gap-3 h-full z-2 relative">
              {%- unless section_rendering_api -%}
                <api-button class="api-only" data-id="announcement_localization_country_form" data-section-id="{{ section.id }}"></api-button>
              {%- endunless -%}
              {%- render 'icon', icon: 'currency', size: 'xs', class: 'stroke-1 hidden xl:block' -%}
              <span class="leading-tight">{{ localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})</span>
              {%- render 'icon', icon: 'chevron-down', size: 'xs' -%}
            </button>
            <dropdown-localization class="dropdown opacity-0 invisible z-30 absolute top-100 right-0 pointer-events-none" id="CountryLocalization-{{ section.id }}">
              {%- unless section_rendering_api -%}
                <div class="dropdown__container" id="announcement_localization_country_form"></div>
              {%- else -%}
                {%- form 'localization', id: 'announcement_localization_country_form', class: 'dropdown__container', is: 'localization-listbox' -%}
                  {%- render 'corner', dir: 'top', prefix: 'dropdown' -%}
                  <ul class="dropdown__nav flex flex-col gap-1d5 xl:gap-2" role="list">
                    {%- for country in localization.available_countries -%}
                      <li class="opacity-0">
                        <p>
                          <a class="reversed-link{% if country.iso_code == localization.country.iso_code %} active pointer-events-none{% endif %}"
                            href="#"
                            {% if country.iso_code == localization.country.iso_code %}
                              aria-current="true"
                            {% endif %}
                            data-value="{{ country.iso_code }}"
                            title="{{ country.name | escape }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})"
                            data-no-instant
                          >
                            {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                          </a>
                        </p>
                      </li>
                    {%- endfor -%}
                  </ul>
                  <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}" />
                {%- endform -%}
              {%- endunless -%}
            </dropdown-localization>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar v2",
  "class": "topbar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "Show social media icons"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Enable language selector"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "Enable country/region selector"
    },
    {
      "type": "checkbox",
      "id": "invert_icons_selectors",
      "default": false,
      "label": "Invert icons and selectors"
    },
    {
      "type": "header",
      "content": "Announcement"
    },
    {
      "type": "select",
      "id": "announcement_position",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Announcement position",
      "info": "Position is automatically optimized for mobile."
    },
    {
      "type": "select",
      "id": "announcement_layout",
      "options": [
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "marquee",
          "label": "Marquee"
        }
      ],
      "default": "carousel",
      "label": "Announcement layout"
    },
    {
      "visible_if": "{{ section.settings.announcement_layout == 'carousel' }}",
      "type": "checkbox",
      "id": "autoplay",
      "default": true,
      "label": "Autoplay"
    },
    {
      "visible_if": "{{ section.settings.announcement_layout == 'carousel' and section.settings.autoplay == true }}",
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autospeed",
      "max": 10,
      "min": 3,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "visible_if": "{{ section.settings.announcement_layout == 'carousel' }}",
      "type": "checkbox",
      "id": "show_navigation",
      "default": false,
      "label": "Show navigation"
    },
    {
      "visible_if": "{{ section.settings.announcement_layout == 'marquee' }}",
      "type": "select",
      "id": "direction",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Direction"
    },
    {
      "visible_if": "{{ section.settings.announcement_layout == 'marquee' }}",
      "type": "range",
      "id": "speed",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Speed",
      "unit": "x",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Gradient replaces solid colors when set"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#1f1f1f"
    },
    {
      "type": "color_background",
      "id": "gradient_background",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "color_highlight",
      "label": "Highlight",
      "default": "#ffddbf"
    },
    {
      "type": "color_background",
      "id": "gradient_highlight",
      "label": "Highlight gradient"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "checkbox",
      "id": "hide_homepage",
      "label": "Do not show on home page",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "Make section rounded"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "alert", "label": "Alert" },
            { "value": "award", "label": "Award" },
            { "value": "bag", "label": "Bag" },
            { "value": "box", "label": "Box" },
            { "value": "briefcase", "label": "Briefcase" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "chat_bubble", "label": "Chat bubble" },
            { "value": "check_mark", "label": "Check mark" },
            { "value": "clipboard", "label": "Clipboard" },
            { "value": "cosmetics", "label": "Cosmetics" },
            { "value": "creadit_card", "label": "Credit card" },
            { "value": "dairy", "label": "Dairy" },
            { "value": "dairy_free", "label": "Dairy free" },
            { "value": "devices", "label": "Devices" },
            { "value": "email", "label": "Email" },
            { "value": "eye", "label": "Eye" },
            { "value": "file_text", "label": "File text" },
            { "value": "gift", "label": "Gift" },
            { "value": "gluten", "label": "Gluten" },
            { "value": "gluten_free", "label": "Gluten free" },
            { "value": "headphone", "label": "Headphone" },
            { "value": "heart", "label": "Heart" },
            { "value": "iron", "label": "Iron" },
            { "value": "lightning", "label": "Lightning" },
            { "value": "lock", "label": "Lock" },
            { "value": "map_pin", "label": "Map pin" },
            { "value": "newspaper", "label": "Newspaper" },
            { "value": "organic", "label": "Organic" },
            { "value": "perfume", "label": "Perfume" },
            { "value": "phone", "label": "Phone" },
            { "value": "plane", "label": "Plane" },
            { "value": "planet", "label": "Planet" },
            { "value": "planet_2", "label": "Planet 2" },
            { "value": "recycling", "label": "Recycling" },
            { "value": "return", "label": "Return" },
            { "value": "rocket", "label": "Rocket" },
            { "value": "ruler", "label": "Ruler" },
            { "value": "ruler_2", "label": "Ruler 2" },
