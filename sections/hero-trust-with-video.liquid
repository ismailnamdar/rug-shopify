{% comment %}
  sections/hero-trust-figma.liquid
  Hero section powered by Figma nodes (14:95 video bg, 14:56 trust, 14:81 h1, 14:82 subhead, 14:83 CTA, 14:137 features)
  - All CSS is inline in this section file per request.
  - Minimal settings; avoids unused options from hero-trust.
{% endcomment %}

<style>
  .section--rugtomize-image-grid {
    max-width: 1200px;
    display: flex;
    justify-content: center;
  }
  .hf-hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    text-align: left;
    color: #fff;
    aspect-ratio: {{ section.settings.poster_desktop.width }} / {{ section.settings.poster_desktop.height }};
    min-height: 600px;
    max-height: calc(100vh - 210px);
    padding: 10px 16px 56px 13px;
  }

  .hf-hero__video {
    position: absolute;
    inset: 0;
    width: 100vw;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .hf-hero__mobile-image {
    display: none;
  }

  .hf-hero__desktop-image {
    display: block;
  }

  .hf-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--hf-overlay-opacity, 0.4));
  }

  .hf-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    gap: 9px;
    display: flex;
    flex-direction: column;
  }

  /* Trust line + rating stars */
  .hf-trust {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 9px;
    font-weight: 400;
    font-size: 14px;
    margin-bottom: 10px;
  }

  .hf-trust__line {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: black;
  }

  .hf-stars {
    display: inline-flex;
    gap: 2px;
  }

  .hf-stars svg {
    width: 24px;
    height: 24px;
    fill: #febf00;
    display: block;
  }

  .hf-rating {
    font-weight: 400;
    font-size: 17px;
    font-family: 'Campton', sans-serif;
  }

  .hf-trust__text {
    font-size: 18px;
    line-height: normal;
    max-width: 476px;
    color: black;
    font-family: 'Campton', sans-serif;
    font-weight: 400;
  }

  /* Main heading */
  .hf-title {
    font-family: 'Campton', sans-serif;
    font-size: 52px;
    line-height: 69px;
    color: black;
    font-style: normal;    
    text-transform: none;
    max-width: 650px;
    font-weight: 500;
    letter-spacing: 0px;
    margin: 0;
  }

  /* Subhead */
  .hf-sub {
    font-size: 27px;
    line-height: 33px;
    font-weight: 400;
    letter-spacing: 0px;
    color: black;
    font-family: 'Campton', sans-serif;
    font-weight: 300;
  }

  /* CTA */
  .hf-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #febf00;
    color: black;
    font-weight: 800;
    padding: 23px 10px;
    border-radius: 10px;
    text-decoration: none;
    min-width: 310px;
    min-height: 80px;
    justify-content: center;

  }

  .hf-cta span {
    font-size: 28px;
    font-family: 'Campton', sans-serif;
    font-weight: 300;
    line-height: normal;
  }

  /* Features row */
  .hf-features {
    background: #f3f3f3;
  }

  .hf-features__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px 16px;
  }

  .hf-features__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .hf-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .hf-feature__icon {
    width: 40px;
    height: 40px;
  }

  .hf-feature__text {
    font-weight: 700;
    color: #111;
    font-size: 17px;
    line-height: 21px;
    text-align: center;
  }

  @media screen and (max-width: 768px) {
    .hf-hero {
      padding: 19px 15px;
      max-width: 100%;
      align-items: flex-start;
      justify-content: center;
      text-align: center;
      aspect-ratio: {{ section.settings.poster_mobile.width }} / {{ section.settings.poster_mobile.height }};
      min-height: 400px;
      height: calc(100vh - 400px);
      width: 100%;
    }

    .hf-hero__video {
      
    }

    .hf-hero__inner {
      gap: 9px;
    }

    .hf-trust {
      align-items: center;
      margin-bottom: 0;
    }

    .hf-trust__text {
      display: none;
    }

    .hf-title {
      font-size: 29px;
      line-height: 34px;
      max-width: 400px;x
    }

    .hf-sub {
      font-size: 15px;
      line-height: 19px;
      letter-spacing: 1px;
    }

    .hf-features__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hf-hero__mobile-image {
      display: block;
    }

    .hf-hero__desktop-image {
      display: none;
    }

    .hf-cta {
      min-height: 64px;
      min-width: unset;
      padding: 11px;
      min-height: unset;
      border-radius: 6px;
    }

    .hf-cta span {
      font-size: 14px;
      line-height: 17px;
    }
  }
</style>

<section class="hf-hero" style="--hf-overlay-opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}">
  {% comment %} Video background: prefer uploaded video; fallback to external URL; optional poster {% endcomment %}
  {% if section.settings.media_type == "video" %}
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, class: 'hf-hero__video' }}
    {% elsif section.settings.video_url != blank %}
      <video class="hf-hero__video" autoplay loop muted playsinline {% if section.settings.poster %}poster="{{ section.settings.poster | img_url: '2000x' }}"{% endif %}>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
  {% elsif section.settings.media_type == "image" %}
    {% if section.settings.poster_desktop or section.settings.poster_mobile or section.settings.poster %}
      {% assign poster_desktop = section.settings.poster_desktop | default: section.settings.poster %}
      {% assign poster_mobile = section.settings.poster_mobile | default: section.settings.poster %}
      {% assign poster_alt = section.settings.poster_alt | default: section.settings.title | escape %}

      <picture class="hf-hero__mobile-image">
        {% if poster_mobile != blank %}
          <source
            media="(max-width: 768px)"
            srcset="{{ poster_mobile | img_url: '480x' }} 480w, {{ poster_mobile | img_url: '800x' }} 800w"
            sizes="(max-width: 768px) 100vw, 50vw">
          <source
            media="(min-width: 769px)"
            srcset="{{ poster_mobile | img_url: '800x' }} 800w, {{ poster_mobile | img_url: '1200x' }} 1200w, {{ poster_mobile | img_url: '2000x' }} 2000w"
            sizes="100vw">
        {% endif %}

        <img
          class="hf-hero__video"
          src="{{ poster_mobile | img_url: '1200x' }}"
          alt="{{ poster_alt }}"
          loading="lazy" />
      </picture>

      <picture class="hf-hero__desktop-image">
        {% if poster_desktop != blank %}
          <source
            media="(max-width: 768px)"
            srcset="{{ poster_desktop | img_url: '480x' }} 480w, {{ poster_desktop | img_url: '800x' }} 800w"
            sizes="(max-width: 768px) 100vw, 50vw">
          <source
            media="(min-width: 769px)"
            srcset="{{ poster_desktop | img_url: '800x' }} 800w, {{ poster_desktop | img_url: '1200x' }} 1200w, {{ poster_desktop | img_url: '2000x' }} 2000w"
            sizes="100vw">
        {% endif %}

        <img
          class="hf-hero__video"
          src="{{ poster_desktop | img_url: '1200x' }}"
          alt="{{ poster_alt }}"
          loading="lazy" />
      </picture>
    {% endif %}
  {% endif %}
  <div class="hf-hero__overlay" aria-hidden="true"></div>

  <div class="hf-hero__inner">
    {% if section.settings.title != blank %}
      <h1 class="hf-title">{{ section.settings.title }}</h1>
    {% endif %}

    {% if section.settings.subhead != blank %}
      <div class="hf-sub">{{ section.settings.subhead }}</div>
    {% endif %}

    <div class="hf-trust">
      <div class="hf-trust__line">
        <span class="hf-stars" aria-hidden="true">
          <img
            src="{{ 'review-stars.png' | asset_url }}"
            alt="{{ product.title }}"
            width="135"
            height="26"
          >
          {% comment %} {% for i in (1..5) %}
            {% if forloop.index == 5 %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <mask id="mask0_136_2035" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
                  <rect width="24" height="24" fill="#D9D9D9"/>
                </mask>
                <g mask="url(#mask0_136_2035)">
                  <path d="M14.675 16.175L13.95 13.15L16.325 11.1L13.225 10.825L12 7.94998V14.55L14.675 16.175ZM6.07501 20.6365L7.65776 13.8922L2.42126 9.36923L9.31151 8.79623L12 2.45398L14.6885 8.79623L21.5788 9.36923L16.3423 13.8922L17.925 20.6365L12 17.0635L6.07501 20.6365Z" fill="#FEBF00"/>
                </g>
              </svg>
            {% else %}
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><polygon points="10,1 12.6,7.3 19.5,7.3 13.9,11.8 16.4,18 10,14 3.6,18 6.1,11.8 0.5,7.3 7.4,7.3"/></svg>
            {% endif %}
          {% endfor %} {% endcomment %}
        </span>
        {% if section.settings.rating_value != blank %}<span class="hf-rating">{{ section.settings.rating_value }}</span>{% endif %}
      </div>
      {% if section.settings.trust_text != blank %}<div class="hf-trust__text">{{ section.settings.trust_text }}</div>{% endif %}
    </div>

    {% if section.settings.cta_text != blank %}
      <div>
      <a class="hf-cta" href="{{ section.settings.cta_link | default: '#' }}" onclick="if (window.clarity) { clarity('event', 'Hero primary CTA click'); }">
        <span>{{ section.settings.cta_text }}</span>
      </a>
      </div>
    {% endif %}
  </div>
</section>

{% if section.settings.show_features %}
  <div class="hf-features">
    <div class="hf-features__inner">
      <div class="hf-features__grid">
        {% for block in section.blocks %}
          <div class="hf-feature" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <img class="hf-feature__icon" src="{{ block.settings.icon | img_url: '80x' }}" alt="" />
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="hf-feature__text">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Hero Trust with Video",
  "settings": [
    { "type": "select",
      "id": "media_type", 
      "label": "Media Type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "video"
    },
    { "type": "video", "id": "video", "label": "Background video (uploaded)" },
    { "type": "url", "id": "video_url", "label": "Background video URL (mp4)" },
    { "type": "image_picker", "id": "poster_desktop", "label": "Hero image desktop" },
    { "type": "image_picker", "id": "poster_mobile", "label": "Hero image mobile" },
    { "type": "image_picker", "id": "poster", "label": "Fallback poster image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },

    { "type": "text", "id": "rating_value", "label": "Rating value", "default": "4.55" },
    { "type": "text", "id": "trust_text", "label": "Trust line", "default": "Trusted by 10,000+ businesses and fans of unique spaces" },
    { "type": "text", "id": "title", "label": "Main headline", "default": "Your Design. Our Craftsmanship. Commercial-Grade Premium Rugs Hand-Tailored in USA." },
    { "type": "text", "id": "subhead", "label": "Subheadline", "default": "From Image to Iconic Rug." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "CREATE MY RUG" },
    { "type": "url", "id": "cta_link", "label": "Button link", "default": "/collections/all" },

    { "type": "checkbox", "id": "show_features", "label": "Show features row", "default": true }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text", "default": "Feature" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Trust with Video",
      "category": "Custom",
      "blocks": [
        { "type": "feature", "settings": { "text": "Fast Turnaround" } },
        { "type": "feature", "settings": { "text": "Made in USA" } },
        { "type": "feature", "settings": { "text": "Durable & Easy-Clean" } },
        { "type": "feature", "settings": { "text": "4.9★ User Satisfaction" } }
      ]
    }
  ]
}
{% endschema %}
