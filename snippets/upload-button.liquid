<script src="{{ 'upload-button.js' | asset_url }}" defer></script>

{% assign SUPPORTED_FILE_TYPES = 'image/jpg,image/jpeg,image/webp,image/png,image/svg+xml,image/tiff,image/HEIC,image/bmp,image/avif,.ico' %}

<upload-button data-form-id="{{ product_form_id }}">
  <input id="custom-rug-image" type="file" style="display: none;" accept="{{ SUPPORTED_FILE_TYPES }}" />
  <button
    type="submit"
    name="add"
    form="{{ product_form_id }}"
    class="custom-rug-upload-image product-form__submit button button--primary button--fixed grow w-full{% if show_price %} with-price{% endif %}"
    is="hover-button"
    aria-label="{{ add_to_cart_aria | escape }}"
    {%- if product.selected_or_first_available_variant.available == false or quantity_rule_soldout %} disabled{% endif -%}
    {%- if product.template_suffix == 'pre-order' %} data-pre-order{% endif -%}
    {%- if enable_back_in_stock %} data-back-in-stock{% endif -%}
  >
    <span class="btn-fill" data-fill></span>
    <span class="btn-text flex items-center gap-4">
      <span class="font-bold text-xl">Upload Your Image</span>
      {% render 'icon', icon: 'upload', size: 'xs' %}
    </span>
  </button>
</upload-button>

<div id="upload-btn-sticky-bar" aria-hidden="true">
  <upload-button data-form-id="{{ product_form_id }}" data-sticky>
    <button
      type="submit"
      name="add"
      form="{{ product_form_id }}"
      class="custom-rug-upload-image product-form__submit button button--primary button--fixed grow w-full{% if show_price %} with-price{% endif %}"
      is="hover-button"
      aria-label="{{ add_to_cart_aria | escape }}"
      {%- if product.selected_or_first_available_variant.available == false or quantity_rule_soldout %} disabled{% endif -%}
      {%- if product.template_suffix == 'pre-order' %} data-pre-order{% endif -%}
      {%- if enable_back_in_stock %} data-back-in-stock{% endif -%}
    >
      <span class="btn-fill" data-fill></span>
      <span class="btn-text flex items-center gap-4">
        <span class="font-bold text-xl">Upload Your Image</span>
        {% render 'icon', icon: 'upload', size: 'xs' %}
      </span>
    </button>
  </upload-button>
</div>

<style>
  .custom-rug-upload-image {
    max-width: 503px;
  }

  @media (max-width: 749px) {
    #upload-btn-sticky-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 30;
      padding: 12px 16px;
      background: #fff;
      box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
      /* no height/display toggle = zero CLS */
    }

    #upload-btn-sticky-bar.is-visible {
      opacity: 1;
      pointer-events: auto;
    }

    #upload-btn-sticky-bar .custom-rug-upload-image {
      max-width: 100%;
    }
  }

  @media (min-width: 750px) {
    #upload-btn-sticky-bar {
      display: none;
    }
  }
</style>

<script>
  (function () {
    var mq = window.matchMedia('(max-width: 749px)');
    var bar = document.getElementById('upload-btn-sticky-bar');

    // Find the original (non-sticky) upload-button sibling
    var originalBtn = null;
    var el = bar;
    while (el && el.previousElementSibling) {
      el = el.previousElementSibling;
      if (el.tagName && el.tagName.toLowerCase() === 'upload-button' && !el.hasAttribute('data-sticky')) {
        originalBtn = el;
        break;
      }
    }

    if (!bar || !originalBtn || !window.IntersectionObserver) return;

    // Move bar to document.body so position:fixed is never trapped
    // inside a transformed ancestor (e.g. #product-main-form-container
    // gets transform:translateX applied by the edit-notes flow).
    document.body.appendChild(bar);

    var observer = new IntersectionObserver(function (entries) {
      if (!mq.matches) {
        bar.classList.remove('is-visible');
        bar.setAttribute('aria-hidden', 'true');
        return;
      }
      var isVisible = entries[0].isIntersecting;
      bar.classList.toggle('is-visible', !isVisible);
      bar.setAttribute('aria-hidden', isVisible ? 'true' : 'false');
    }, { threshold: 0, rootMargin: '0px' });

    observer.observe(originalBtn);

    mq.addEventListener('change', function () {
      if (!mq.matches) {
        bar.classList.remove('is-visible');
        bar.setAttribute('aria-hidden', 'true');
      }
    });
  })();
</script>
