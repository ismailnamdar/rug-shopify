{%- doc -%}
  Renders an SVG icon from a comprehensive icon library with customizable size and styling.

  @param {string} icon - Icon name to render (e.g., 'cart', 'search', 'close')
  @param {string} [size] - Icon size: 'sm', 'md', 'lg'
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'icon',
    icon: 'cart',
    size: 'lg'
  %}
{%- enddoc -%}

{%- capture class -%}icon icon-{{ icon | handle }} icon-{{ size | default: 'md' }}{% if class != blank %} {{ class }}{% endif %}{%- endcapture -%}
