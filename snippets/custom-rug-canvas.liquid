<script src="{{ 'custom-rug-canvas.js' | asset_url }}" defer></script>

{%- assign shape_option_index = 0 -%}
{%- assign size_option_index = 1 -%}
{%- for opt in product.options -%}
  {%- if opt == 'Shape' -%}{%- assign shape_option_index = forloop.index0 -%}{%- endif -%}
  {%- if opt == 'Size' -%}{%- assign size_option_index = forloop.index0 -%}{%- endif -%}
{%- endfor -%}

<custom-rug-canvas
  data-shape="{{ shape | default: 'rectangle' }}"
  data-size="{{ size | default: "2'X3'" }}"
  data-bottom-banner="{{ bottom_banner | default: false }}"
  data-bg-url="{{ bg_url | default: 'background-example.png' | asset_url }}"
  data-bg-big-url="{{ 'background-example-big.png' | asset_url }}"
  data-bg-small-url="{{ 'background-example-small.png' | asset_url }}"
  data-shape-option-index="{{ shape_option_index }}"
  data-size-option-index="{{ size_option_index }}"
>

<div id="rug-canvas-container w-full">
  <div style="position: relative; width: 100%;">
    <canvas id="rug-canvas" class="rug-canvas"></canvas>
    {% render 'circular-progress' %}

    <div class="custom-rug-top-toolbar">
      <div style="font-size: 12px; line-height: 14px; display: flex; flex-direction: row; text-align:center;">
        <button id="rug-canvas-change-photo" class="custom-rug-action-button">
          <span style="font-weight: 700; font-size: 14px;">Change Photo</span>
          {% render 'icon', icon: 'upload', size: 'xs' %}
        </button>
      </div>
    </div>

    <div class="custom-rug-right-toolbar">
      <div class="rug-color-container flex justify-center items-center">
        Rug Color
        <input id="custom-rug-bg-color" data-bg-color="color" class="custom-rug-bg-color" type="color" />
      </div>
      <button id="rug-canvas-rotate" class="custom-rug-action-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rotate-ccw" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
      </button>
      <div style="display: flex; flex-direction: column; border-radius: 10px; overflow: hidden; box-shadow: 0 1px 1px #23232347; background-color: white;border: 1px solid black;">
        <button id="rug-canvas-scale-up" class="custom-rug-action-button-zoom">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
        </button>
        <button id="rug-canvas-scale-down" class="custom-rug-action-button-zoom">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-minus" aria-hidden="true"><path d="M5 12h14"></path></svg>
        </button>
      </div>
    </div>

    <div class="custom-rug-bottom-toolbar">
      <div class="crc-bottom-card">
        <div>
          <div class="crc-bottom-card-title"><span>Our Design Team Will:</span></div>
          <div>
              <ul style="list-style: disc; padding-left: 16px;">
                <li>
                Center Design Appropriately
                </li>
                <li>
                  Enhance Design Quality
                </li>
              </ul>
            </li>
          </div>
        </div>
        <div style="width: 1px; background-color: black; display: block;"></div>
        <div>
          <div class="crc-bottom-card-title"><span>Post Purchase We Can:</span></div>
          <div>
              <ul style="list-style: disc; padding-left: 16px;">
                <li>
                  Modify Background Color
                </li>
                <li>
                  Provide Proof Before Production
                </li>
              </ul>
            </li>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% comment Phase 2. Preview images %}
  {% assign asset_images = "circle-example-1.webp,circle-example-2.webp,circle-example-3.webp,circle-example-4.webp" | split: "," %}
  <div class="image-grid">
    {% for img in asset_images %}
      <div class="grid-item">
        <img src="{{ img | asset_url }}" alt="Preview Image" loading="lazy">
      </div>
    {% endfor %}
  </div>
  {% endcomment %}
</div>

<style>
  .rug-canvas {
    width: 100%;
    height: 600px;
    touch-action:none;
  }
  .custom-rug-action-button {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: white;
    border: 1px solid black;
    border-radius: 10px;
    margin: 6px 0;
    padding: 8px;
    cursor: pointer;
    box-shadow: 0 1px 1px #23232347;
  }

  .custom-rug-action-button-zoom {
    height: 57px;
    width: 57px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  .custom-rug-top-toolbar {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    color: black !important;
  }
  .custom-rug-right-toolbar {
    position: absolute;
    right: 10px;
    bottom: 12px;
  }

  .custom-rug-bottom-toolbar {
    position: absolute;
    left: 12px;
    bottom: 12px;
    width: 500px;
    max-width: 80%;
  }

  #chatra {
    bottom: 85px !important;
  }

  .phone-button {
    bottom: 85px !important
  }

  .rug-color-container {
    font-size: 12px;
    line-height: 14px;
    font-weight: bold;
    display: flex;
    flex-direction: column;
    width: 57px;
    text-align:center;
    color: black;
    border-radius: 10px;
    background-color: white;
    margin-bottom: 12px;
    padding: 8px 8px 2px 8px;
    border: 1px solid black;
  }

  .custom-rug-bg-color {
    height: 45px;
    border-radius: 7px;
    padding: 2px !important;
    margin-bottom: 0 !important;
    margin-top: 4px !important;
    box-shadow: 0 1px 1px #23232347;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .image-grid .grid-item img {
    width: 100%;
    aspect-ratio: 1/1;
    display: block;
    object-fit: cover;
  }

  #rug-canvas-rotate {
    margin-bottom: 10px;
    height: 57px;
    width: 57px;
  }

  #rug-canvas-change-photo {
    margin-top: 6px;
    padding: 8px 40px;
    height: 57px;
    border-radius: 29px;
  }

  .crc-bottom-card {
    display: flex;
    gap: 20px;
    padding: 12px;
    border-radius: 10px;
    background-color: white;
    border: 1px solid black;
    box-shadow: 0 1px 1px #23232347;
    color: black;
  }

  .crc-bottom-card-title {
    font-weight: 700;
    font-size: 17px;
    line-height: 19px;
    letter-spacing: 0px;
    margin-bottom: 8px;
  }

  @media screen and (max-width: 768px) {
    .rug-canvas {
      height: 450px;
    }

    .custom-rug-bottom-toolbar {
      left: 2px;
      bottom: 2px;
      transform: unset;
      width: 440px;
      max-width: 80%;
    }

    .custom-rug-right-toolbar {
      position: absolute;
      right: 2px;
      bottom: 2px;
    }

    .custom-rug-top-toolbar {
      top: 10px;
    }

    .rug-color-container {
      width: 40px;
    }

    .custom-rug-action-button-zoom {
      height: 40px;
      width: 40px;
    }

    #rug-canvas-change-photo {
      height: 40px;
      width: 220px;
    }

    #rug-canvas-rotate {
      height: 40px;
      width: 40px;
    }

    .custom-rug-bg-color {
      width: 30px;
      height: 30px;
    }

    .crc-bottom-card {
      padding: 10px;
      gap: 10px;
    }

    .crc-bottom-card-title {
      font-size: 12px;
      margin-bottom: 4px;
    }

    .crc-bottom-card {
      font-size: 12px;
    }
  }

  @media screen and (max-width: 500px) {
    .custom-rug-bottom-toolbar {
      width: 350px;
    }
    .crc-bottom-card {
      padding: 8px;
      gap: 8px;
    }

    .crc-bottom-card-title {
      font-size: 10px;
    }

    .crc-bottom-card {
      font-size: 10px;
    }
  }
</style>

</custom-rug-canvas>