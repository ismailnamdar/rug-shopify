    "custom_liquid_qn7HBA": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<section style=\"background: #FFFFFF; padding: 80px 0; font-family: 'Inter', sans-serif;\">\n  <div style=\"max-width: 800px; margin: 0 auto; padding: 0 20px;\">\n    <h2 style=\"font-size: clamp(28px, 5vw, 42px); font-weight: 700; text-align: center; color: #000; margin: 0 0 48px;\">Frequently Asked Questions</h2>\n\n    <div class=\"rt-faq-list\">\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">What materials are your custom mats made from?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">Our mats are made from premium, heavy-duty materials designed to withstand high foot traffic while maintaining vibrant print quality. Each mat features a durable rubber backing and a soft, fade-resistant surface.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">How long does shipping take?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">Orders ship within 2 business days. Standard delivery typically takes 5-7 business days depending on your location. Expedited shipping options are available at checkout.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">Can I upload my own logo or design?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">Absolutely! You can upload your own logo, artwork, or design during the customization process. We support PNG, JPG, and SVG files. Our team will also send you a free proof before production to make sure everything looks perfect.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">What is the print resolution?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">All of our mats are printed in stunning 4K resolution, ensuring crisp, vibrant details that make your brand stand out. The high-quality printing process ensures colors stay true even after extended use.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">How do I clean my custom mat?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">Our mats are designed for easy maintenance. Simply vacuum, shake out, or spot clean with mild soap and water. The durable surface resists stains and can be hosed down for a deeper clean.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">Do you offer bulk or wholesale pricing?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">Yes! We offer competitive pricing for bulk orders. Contact our team for a custom quote tailored to your business needs. No contracts or subscriptions required.</p>\n        </div>\n      </div>\n\n      <div class=\"rt-faq-item\" style=\"border-top: 1px solid #E5E5E5; border-bottom: 1px solid #E5E5E5;\">\n        <button class=\"rt-faq-btn\" style=\"width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; background: none; border: none; cursor: pointer; font-family: inherit; text-align: left;\">\n          <span style=\"font-size: 16px; font-weight: 600; color: #000;\">What is your return policy?</span>\n          <svg class=\"rt-faq-icon\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" style=\"flex-shrink: 0; margin-left: 16px; transition: transform 0.3s;\"><path d=\"M5 7.5L10 12.5L15 7.5\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </button>\n        <div class=\"rt-faq-answer\" style=\"max-height: 0; overflow: hidden; transition: max-height 0.3s ease;\">\n          <p style=\"padding: 0 0 20px; margin: 0; font-size: 15px; line-height: 1.6; color: #555;\">We stand behind the quality of our products. If you're not satisfied with your mat, please reach out to our 24/7 customer support team and we'll make it right.</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n(function() {\n  document.querySelectorAll('.rt-faq-btn').forEach(function(btn) {\n    btn.addEventListener('click', function() {\n      var item = btn.parentElement;\n      var answer = item.querySelector('.rt-faq-answer');\n      var icon = btn.querySelector('.rt-faq-icon');\n      var isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';\n\n      // Close all others\n      document.querySelectorAll('.rt-faq-answer').forEach(function(a) { a.style.maxHeight = '0px'; });\n      document.querySelectorAll('.rt-faq-icon').forEach(function(i) { i.style.transform = 'rotate(0deg)'; });\n\n      if (!isOpen) {\n        answer.style.maxHeight = answer.scrollHeight + 'px';\n        icon.style.transform = 'rotate(180deg)';\n      }\n    });\n  });\n})();\n</script>",
