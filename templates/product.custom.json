        },
        "collapsible_tab-4": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "box",
            "iwidth": "custom",
            "icon_width": 24,
            "heading": "Product Details & Quality",
            "content": "<p> </p>",
            "metafields": "",
            "text_size": "text-base",
            "sub_row_1_heading": "What are your rugs made of?",
            "sub_row_1_content": "<p>Commercial-grade polyester with non-slip rubber or vinyl backing.</p>",
            "sub_row_2_heading": "Will rugs stay flat in high-traffic areas?",
            "sub_row_2_content": "<p>Yes—weight-balanced and reinforced.</p>",
            "sub_row_3_heading": "Are they durable enough for daily use?",
            "sub_row_3_content": "<p>Absolutely—built to last under heavy traffic.</p>",
            "sub_row_4_heading": "Are they easy to clean?",
            "sub_row_4_content": "<p>Vacuum regularly or hose down with mild soap.</p>",
            "sub_row_5_heading": "Can they be used outdoors?",
            "sub_row_5_content": "<p>Yes—fade and moisture resistant.</p>",
            "sub_row_6_heading": "Do they have non-slip backing?",
            "sub_row_6_content": "<p>Every rug ships with an anti-slip base.</p>",
            "sub_row_7_heading": "How thick are the rugs?",
            "sub_row_7_content": "<p>About 0.4″ (10 mm)—ADA-compliant.</p>"
          }
        },
        "collapsible_tab_Tiw9wh": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "shield",
            "iwidth": "custom",
            "icon_width": 24,
            "heading": "Trust & Satisfaction (Proofs, Guarantees, Design Assurance)",
            "content": "<p> </p>",
            "metafields": "",
            "text_size": "text-base",
            "sub_row_1_heading": "Can I see a free proof or mockup before production?",
            "sub_row_1_content": "<p>Request a free digital proof by adding a note at checkout or replying to your confirmation email within 24 hours.</p>",
            "sub_row_2_heading": "Can I request a refund if I don’t like the proof?",
            "sub_row_2_content": "<p>Yes—reply within 24 hours and we’ll issue a full refund before production.</p>",
            "sub_row_3_heading": "How long do I have to request design or color changes?",
            "sub_row_3_content": "<p>You have 24 hours after ordering to submit any change requests.</p>",
            "sub_row_4_heading": "What happens if I don't submit design instructions?",
            "sub_row_4_content": "<p>We’ll proceed with your uploaded artwork and our design standards.</p>",
            "sub_row_5_heading": "How many design variations can I request?",
