            "heading": "Shapes & Sizes",
            "content": "<p> </p>",
            "metafields": "",
            "text_size": "text-base",
            "sub_row_1_heading": "Do you offer custom shapes?",
            "sub_row_1_content": "<p>Yes—describe your shape in checkout notes or email us.</p>",
            "sub_row_2_heading": "Do you offer custom sizes?",
            "sub_row_2_content": "<p>Pick the closest size and give exact dimensions; we’ll invoice any upcharge.</p>",
            "sub_row_3_heading": "",
