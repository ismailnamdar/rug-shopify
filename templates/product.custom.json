        "collapsible_tab-3": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "wrench",
            "iwidth": "custom",
            "icon_width": 24,
            "heading": "Customization & Design Options",
            "content": "<p> </p>",
            "metafields": "",
            "text_size": "text-base",
            "sub_row_1_heading": "Do you offer design assistance?",
            "sub_row_1_content": "<p>Yes—free logo cleanup, layout help, color guidance, and concept creation.</p>",
            "sub_row_2_heading": "Will my design be centered and sized correctly?",
            "sub_row_2_content": "<p>Absolutely—every design is manually adjusted for balance.</p>",
            "sub_row_3_heading": "Can I add text, images, or multiple logos?",
            "sub_row_3_content": "<p>Sure—upload everything at checkout or email us within 24 hours.</p>",
            "sub_row_4_heading": "Can you rotate my design?",
            "sub_row_4_content": "<p>Yes—just specify your rotation preference.</p>",
