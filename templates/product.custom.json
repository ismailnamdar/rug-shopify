      "blocks": {
        "collapsible_tab-1": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "award",
            "iwidth": "custom",
            "icon_width": 24,
            "heading": "Backgrounds, Color & Logo Styling",
            "content": "<p> </p>",
            "metafields": "",
            "text_size": "text-base",
            "sub_row_1_heading": "How do I choose or change the background color?",
            "sub_row_1_content": "<p>Include your hex code or reference in checkout notes or email us.</p>",
            "sub_row_2_heading": "Can I change the background color after ordering?",
            "sub_row_2_content": "<p>Yes—within 24 hours of purchase.</p>",
            "sub_row_3_heading": "Can I request a black/grey background with a white logo?",
            "sub_row_3_content": "<p>Absolutely—specify it in your notes.</p>",
            "sub_row_4_heading": "Can you invert my logo?",
            "sub_row_4_content": "<p>Of course—let us know light-to-dark or vice versa.</p>",
            "sub_row_5_heading": "Will the colors match the final product?",
            "sub_row_5_content": "<p>We aim for 95–100% accuracy; slight variation may occur.</p>",
            "sub_row_6_heading": "",
            "sub_row_6_content": "",
            "sub_row_7_heading": "",
